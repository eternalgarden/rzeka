{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "lib": ["dom", "esnext"],
        "useDefineForClassFields": false
    },
    "include": ["src", "typings"]
}
